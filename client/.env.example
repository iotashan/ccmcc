# Claude Code UI Client Configuration
# Copy this file to .env and fill in the values

# Server address (required)
CLAUDE_CODE_UI_SERVER_ADDRESS=http://your-server:3020

# Machine name (optional, defaults to hostname)
CLAUDE_CODE_UI_CLIENT_NAME="My Remote Machine"

# Authentication token (required)
# Get this from the Claude Code UI settings
CLAUDE_CODE_UI_AUTH_TOKEN=your-jwt-token-here