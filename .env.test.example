# Claude Code UI Test Environment Configuration
# Copy this file to .env.test and fill in your values

# JWT Configuration
JWT_SECRET=your-test-jwt-secret-here-min-32-chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# API Authentication
CLIENT_API_TOKEN=your-test-api-token-here
CLAUDE_API_KEY=your-claude-api-key-here

# Test User Credentials
TEST_USER_EMAIL=testuser@example.com
TEST_USER_PASSWORD=testpass123
TEST_USER_USERNAME=testuser
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=adminpass123
TEST_ADMIN_USERNAME=admin

# Database Configuration
DATABASE_URL=sqlite:///data/test.db
DATABASE_LOG=false
DATABASE_SYNC=true

# Server Configuration
NODE_ENV=test
SERVER_PORT=3020
SERVER_HOST=0.0.0.0
CLIENT_PORT=3021
WS_HEARTBEAT_INTERVAL=30000

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_FILE=/logs/test.log

# Test Mode Settings
ENABLE_TEST_MODE=true
MOCK_CLAUDE_API=true
TEST_TIMEOUT=30000
HEADLESS_BROWSER=true

# Mock Configuration
MOCK_CLAUDE_RESPONSES_PATH=/test-data/mock-responses.json
MOCK_DELAY_MS=100

# Test Data Paths
TEST_PROJECTS_PATH=/test-data/projects
TEST_SESSIONS_PATH=/test-data/sessions
TEST_CREDENTIALS_PATH=/test-data/credentials

# Performance Settings
MAX_CONCURRENT_TESTS=4
TEST_RETRY_COUNT=2
SCREENSHOT_ON_FAILURE=true

# Optional: External Services (for integration tests)
# GITHUB_TEST_TOKEN=your-github-token-for-testing
# GITLAB_TEST_TOKEN=your-gitlab-token-for-testing