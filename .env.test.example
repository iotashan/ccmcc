# Claude Code UI Test Environment Configuration
# Copy this file to .env.test and fill in your values

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET=your-test-jwt-secret-here-min-32-chars-change-this
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# API Authentication
# ============================================
# Client API tokens for different machines
CLIENT_API_TOKEN=your-test-api-token-here
CLIENT_API_TOKEN_1=test-client-api-token-machine-1
CLIENT_API_TOKEN_2=test-client-api-token-machine-2
CLIENT_API_TOKEN_3=test-client-api-token-machine-3
CLIENT_API_TOKEN_OFFLINE=test-client-api-token-offline

# Claude API (for testing, we'll use mocks)
CLAUDE_API_KEY=your-claude-api-key-here
MOCK_CLAUDE_API=true
MOCK_CLAUDE_RESPONSES_PATH=/test-data/mock-responses.json

# ============================================
# Test User Credentials
# ============================================
TEST_USER_EMAIL=testuser@example.com
TEST_USER_PASSWORD=testpass123
TEST_USER_USERNAME=testuser
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=adminpass123
TEST_ADMIN_USERNAME=admin

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=sqlite:///data/test.db
DATABASE_LOG=false
DATABASE_SYNC=true
DATABASE_FORCE_SYNC=false

# ============================================
# Server Configuration
# ============================================
NODE_ENV=test
SERVER_PORT=3020
SERVER_HOST=0.0.0.0
CLIENT_PORT=3021
CLIENT_PORT_1=3021
CLIENT_PORT_2=3022
CLIENT_PORT_3=3023
CLIENT_PORT_OFFLINE=3024
WS_HEARTBEAT_INTERVAL=30000

# ============================================
# Logging
# ============================================
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_FILE=/logs/test.log

# ============================================
# Test Mode Settings
# ============================================
ENABLE_TEST_MODE=true
TEST_TIMEOUT=30000
HEADLESS=true
CI=true

# Test execution control
RUN_UNIT_TESTS=true
RUN_INTEGRATION_TESTS=true
RUN_E2E_TESTS=true
GENERATE_COVERAGE=true

# ============================================
# Mock Configuration
# ============================================
MOCK_DELAY_MS=100

# ============================================
# Test Data Paths
# ============================================
TEST_PROJECTS_PATH=/test-data/projects
TEST_SESSIONS_PATH=/test-data/sessions
TEST_CREDENTIALS_PATH=/test-data/credentials

# ============================================
# Performance Settings
# ============================================
MAX_CONCURRENT_TESTS=4
TEST_RETRY_COUNT=2
SCREENSHOT_ON_FAILURE=true

# ============================================
# Multi-Machine Configuration
# ============================================
MULTI_MACHINE_MODE=true
MAX_MACHINES_PER_USER=5
ENABLE_MACHINE_SWITCHING=true
MACHINE_STATUS_INTERVAL=5000
OFFLINE_AFTER_SECONDS=30

# ============================================
# MCP (Model Context Protocol) Configuration
# ============================================
MCP_SERVERS_ENABLED=true

# ============================================
# Optional: External Services (for integration tests)
# ============================================
# GITHUB_TEST_TOKEN=your-github-token-for-testing
# GITLAB_TEST_TOKEN=your-gitlab-token-for-testing