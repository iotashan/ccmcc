# Developer Mode Environment Variables
# Copy this file to .env.developer and adjust as needed

# Enable developer mode
DEVELOPER_MODE=true

# Pause duration in seconds before navigation and closing
DEVELOPER_PAUSE_DURATION=20

# Server configuration
SERVER_URL=http://localhost:3020
SERVER_PORT=3020

# Client configuration
CLIENT_URL=http://localhost:3021
CLIENT_PORT=3021

# Test configuration
HEADLESS=false
CI=false

# Test user credentials
TEST_USER_EMAIL=testuser@example.com
TEST_USER_PASSWORD=testpass123
TEST_USER_USERNAME=testuser

# JWT configuration (must match server)
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=1h

# API Token for client
CLIENT_API_TOKEN=your-api-token-here

# Optional: Browser selection (chromium, firefox, webkit)
# BROWSER=chromium

# Optional: Specific test timeout override
# TEST_TIMEOUT=60000